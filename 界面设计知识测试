<script>

const answers = [1, 2, 1, 1, 1, 3, 1, 3, 1, 3, 2, 1, 0, 0, 2, 0, 3, 2, 1, 2, 3, 3, 3, 1, 0, 0, 1, 2, 1, 2, 1, 1, 0, 2, 0, 0, 3, 2, 2, 1, 3, 0, 3, 3, 0, 2, 3, 3, 3, 2, 1, 0, 1, 0, 2, 1, 1, 2, 2, 2, 0, 0, 2, 0, 3, 1, 3, 1, 1, 2, 0, 2, 3, 0, 2, 0, 0, 1, 1, 1, 2, 3, 1, 0, 1, 3, 1, 2, 0, 2, 2, 2, 3, 2, 1, 2, 0, 1, 1, 0];

// Timer (60 minutes)
let totalSeconds = 60 * 60;

function updateTimer() {

    let minutes = Math.floor(totalSeconds / 60);
    let seconds = totalSeconds % 60;

    document.getElementById("time").innerText =
        minutes + ":" + (seconds < 10 ? "0" : "") + seconds;

    if (totalSeconds <= 0) {
        submitQuiz();
    }

    totalSeconds--;
}

setInterval(updateTimer,1000);

// Progress

function updateProgress() {

    let total = answers.length;
    let answered = 0;

    for (let i=0;i<total;i++) {
        let radios = document.getElementsByName("q"+i);
        for (let r of radios) {
            if (r.checked) {
                answered++;
                break;
            }
        }
    }

    let percent = (answered/total)*100;
    document.getElementById("progressFill").style.width = percent + "%";
}

// Submit

function submitQuiz() {

    let score = 0;
    let wrongList = "";

    for (let i=0;i<answers.length;i++) {

        let radios = document.getElementsByName("q"+i);
        let selected = -1;

        for (let r of radios) {
            if (r.checked) {
                selected = parseInt(r.value);
            }
        }

        if (selected === answers[i]) {
            score++;
        } else {
            wrongList += "<p>第"+(i+1)+"题 正确答案："+
                         String.fromCharCode(65+answers[i])+"</p>";
        }
    }

    document.getElementById("result").innerHTML =
        "<h2>你的得分："+score+" / "+answers.length+"</h2>" +
        "<h3>错题：</h3>" +
        wrongList;

    window.scrollTo(0,document.body.scrollHeight);
}

</script>

